// --- RED LEDs (mole present) ---
const int moleLEDs[2] = {2, 3};

// --- GREEN LEDs (hit confirmed) ---
const int hitLEDs[2]  = {4, 5};

// --- BUTTONS (one per hole) ---
const int buttons[2]  = {6, 7};

const unsigned long moleTimeout  = 2000;
const unsigned long hitFlashTime = 300;
const unsigned long debounceDelay = 50;

int  currentMole   = -1;
bool moleActive    = false;
unsigned long moleStartTime = 0;
int score = 0;

unsigned long lastDebounceTime[2] = {0, 0};
bool lastRawState[2]   = {false, false}; // raw reading last loop
bool stableState[2]    = {false, false}; // debounce-confirmed state

void setup() {
  Serial.begin(9600);

  for (int i = 0; i < 2; i++) {
    pinMode(moleLEDs[i], OUTPUT);
    pinMode(hitLEDs[i],  OUTPUT);
    pinMode(buttons[i],  INPUT_PULLUP);
    digitalWrite(moleLEDs[i], LOW);
    digitalWrite(hitLEDs[i],  LOW);
  }

  randomSeed(analogRead(A0));
  Serial.println("START");
  pickNewMole();
}

void loop() {
  // Mole timed out — pick a new one
  if (moleActive && (millis() - moleStartTime >= moleTimeout)) {
    digitalWrite(moleLEDs[currentMole], LOW);
    moleActive = false;
    delay(500);
    pickNewMole();
  }

  // Check buttons
  for (int i = 0; i < 2; i++) {
    bool reading = !digitalRead(buttons[i]); // active LOW

    // Reset debounce timer if reading changed
    if (reading != lastRawState[i]) {
      lastDebounceTime[i] = millis();
    }

    // Only act once debounce window has passed
    if ((millis() - lastDebounceTime[i]) > debounceDelay) {
      if (reading && !stableState[i]) { // fresh confirmed press
        if (moleActive && i == currentMole) {
          // Correct hit
          score++;
          digitalWrite(moleLEDs[currentMole], LOW);
          moleActive = false;

          digitalWrite(hitLEDs[i], HIGH);
          delay(hitFlashTime);
          digitalWrite(hitLEDs[i], LOW);

          Serial.println("SCORE:" + String(score)); // tell LCD board
          delay(500);
          pickNewMole();
        }
      }
      stableState[i] = reading; // update confirmed state only after debounce
    }

    lastRawState[i] = reading; // always track raw for debounce timer
  }
}

void pickNewMole() {
  int newMole;
  do {
    newMole = random(0, 2);
  } while (newMole == currentMole);

  currentMole = newMole;
  digitalWrite(moleLEDs[currentMole], HIGH);
  moleStartTime = millis();
  moleActive = true;
}
